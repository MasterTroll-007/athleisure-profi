# Database
DATABASE_URL=jdbc:postgresql://localhost:5433/fitness
DATABASE_USER=fitness
DATABASE_PASSWORD=your-secure-database-password

# JWT - REQUIRED, generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-secret-key-generate-with-openssl

# SMTP (Gmail) - for email verification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# App settings
APP_NAME=Rezervacni system
APP_BASE_URL=https://your-domain.com
IMAGE_TAG=replace-with-deployed-git-sha

# CORS - allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com

# Logging level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Stripe (payment gateway)
# Dashboard: https://dashboard.stripe.com
# Test mode keys start with sk_test_ / pk_test_
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Optional: Override default success/cancel URLs
# STRIPE_SUCCESS_URL=https://your-domain.com/credits?payment=success
# STRIPE_CANCEL_URL=https://your-domain.com/credits?payment=cancel

# Server monitor
MONITOR_USERNAME=admin
MONITOR_PASSWORD=your-secure-monitor-password

# Database backups
DB_BACKUP_INTERVAL_SECONDS=21600
DB_BACKUP_RETENTION_DAYS=7
# Optional off-site target, e.g. b2:fitness-prod-postgres or s3:bucket/path.
# Put the server-only rclone config in deploy/rclone/rclone.conf; it is gitignored.
DB_BACKUP_OFFSITE_RCLONE_REMOTE=
